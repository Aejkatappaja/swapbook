# Pinned environment for visual-regression baselines, so local and CI renders
# are byte-identical (fonts + browser bundled by the Playwright image). Build
# context is the repo root:
#
#   docker build -f test/e2e/Dockerfile.visual -t swapbook-visual .
#   docker run --rm swapbook-visual                       # compare (CI)
#   docker run --rm -v "$PWD/test/e2e/visual:/work/test/e2e/visual" \
#     swapbook-visual npm run test:visual:update          # refresh baselines
FROM mcr.microsoft.com/playwright:v1.61.1-jammy

# Go toolchain to build the demo target + the swapbook binary the tests drive.
ARG GO_VERSION=1.23.4
RUN curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" | tar -C /usr/local -xz
ENV PATH="/usr/local/go/bin:${PATH}"

WORKDIR /work
COPY . .
RUN cd test/e2e && npm ci && npx playwright install chromium

WORKDIR /work/test/e2e
CMD ["npm", "run", "test:visual"]
